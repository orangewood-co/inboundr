PORT=3000
NODE_ENV=production

# Public origins
FRONTEND_ORIGIN=https://app.example.com
API_ORIGIN=https://api.example.com
EMBED_ORIGIN=https://forms.example.com
LANDING_ORIGIN=https://inboundr.co

# Database
MONGODB_URI=mongodb+srv://USER:PASSWORD@CLUSTER.mongodb.net/btsa?retryWrites=true&w=majority

# Auth and Google OAuth
BETTER_AUTH_SECRET=generate-a-32-byte-secret
BETTER_AUTH_URL=https://api.example.com
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret
# Must exactly match an authorized redirect URI in Google Cloud.
GMAIL_OAUTH_REDIRECT_URI=https://api.example.com/api/v1/gmail/callback
ORGANIZATION_LIMIT=5

# Gmail Pub/Sub
GMAIL_PUBSUB_TOPIC=projects/YOUR_GCP_PROJECT/topics/YOUR_TOPIC

# AI chat
OPENROUTER_API_KEY=sk-or-your-openrouter-key
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
CHAT_MODEL=openai/gpt-5.5
CHAT_TITLE_MODEL=openai/gpt-5.5-mini

# Document embeddings for chat context (RAG). OpenRouter does not serve
# embeddings, so this uses the OpenAI API directly (text-embedding-3-small).
# The same key powers the voice support agent (OpenAI Realtime over SIP).
OPENAI_API_KEY=sk-your-openai-key

# Voice support (OpenAI Realtime + Vobiz SIP)
# Project that owns the realtime webhook; configure the SIP origination URI in
# Vobiz to proj_xxx@sip.api.openai.com:5061 using this id.
OPENAI_PROJECT_ID=proj_your-project-id
# Webhook signing secret from platform.openai.com > Project > Webhooks.
OPENAI_WEBHOOK_SECRET=whsec_your-webhook-secret
OPENAI_REALTIME_MODEL=gpt-realtime-2

# Vobiz REST credentials (Recordings API: the backend polls for call recordings)
VOBIZ_AUTH_ID=your-vobiz-auth-id
VOBIZ_AUTH_TOKEN=your-vobiz-auth-token
VOBIZ_API_BASE_URL=https://api.vobiz.ai/api/v1

# AWS SES
AWS_SES_REGION=ap-south-1
AWS_SES_FROM_EMAIL=no-reply@example.com

# Add any local encryption/signing secrets used by the app here.
# Keep the real production .env file on the EC2 instance only.
