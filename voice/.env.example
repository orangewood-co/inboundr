# LiveKit Cloud project credentials (Settings > API Keys)
LIVEKIT_URL=wss://your-project.livekit.cloud
LIVEKIT_API_KEY=APIxxxxxxxxxxxxx
LIVEKIT_API_SECRET=secretxxxxxxxxxx

# Inboundr backend internal API
BACKEND_URL=http://localhost:3000
# Must match VOICE_INTERNAL_API_KEY in the backend .env
VOICE_INTERNAL_API_KEY=generate-a-long-random-secret

# Agent dispatch name; must match the LiveKit dispatch rule's agent name exactly
VOICE_AGENT_NAME=inboundr-voice

# Optional: dialed-number fallback for local testing without SIP (agents playground)
# VOICE_DEFAULT_NUMBER=+918071387434

# Optional: model overrides (LiveKit Inference)
# VOICE_STT_MODEL=deepgram/nova-3
# VOICE_TTS_MODEL=cartesia/sonic-3
# VOICE_TTS_VOICE=9626c31c-bec5-4cca-baa8-f8ba9e84c8bc
# VOICE_LLM_MODEL=openai/gpt-4.1

# Optional: call recording via LiveKit egress to S3 (all four required to enable).
# These credentials are sent to LiveKit Cloud so its egress workers can upload to your bucket;
# use a dedicated IAM user that can only PutObject under voice-recordings/*.
# VOICE_RECORDING_S3_BUCKET=your-bucket
# VOICE_RECORDING_S3_REGION=ap-south-1
# VOICE_RECORDING_S3_ACCESS_KEY=AKIA...
# VOICE_RECORDING_S3_SECRET=...
