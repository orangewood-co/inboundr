{
  "name": "@btsa/voice",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "clean": "rm -rf dist",
    "typecheck": "tsc --noEmit",
    "download-files": "npm run build && npx livekit-agents download-files",
    "dev": "npm run build && node dist/main.js dev",
    "start": "node dist/main.js start"
  },
  "engines": {
    "node": ">=22.0.0"
  },
  "dependencies": {
    "@livekit/agents": "^1.4.5",
    "@livekit/agents-plugin-livekit": "^1.4.5",
    "@livekit/agents-plugin-silero": "^1.4.5",
    "dotenv": "^17.4.1",
    "livekit-server-sdk": "^2.9.0",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@types/node": "^22.19.17",
    "typescript": "^5.9.3"
  }
}
