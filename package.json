{
  "name": "btsa",
  "private": true,
  "type": "module",
  "workspaces": [
    "backend",
    "frontend",
    "landing",
    "embed"
  ],
  "scripts": {
    "dev:backend": "bun run --cwd backend dev",
    "dev:frontend": "bun run --cwd frontend dev",
    "dev:landing": "bun run --cwd landing dev",
    "email:dev": "bun run --cwd backend email:dev",
    "build": "bun run --cwd frontend build",
    "build:frontend": "bun run --cwd frontend build",
    "build:landing": "bun run --cwd landing build",
    "lint": "bun run --cwd frontend lint",
    "lint:frontend": "bun run --cwd frontend lint",
    "lint:landing": "bun run --cwd landing lint",
    "format": "bun run --cwd frontend format",
    "format:frontend": "bun run --cwd frontend format",
    "format:landing": "bun run --cwd landing format",
    "typecheck": "bun run --cwd backend typecheck && bun run --cwd frontend typecheck",
    "typecheck:backend": "bun run --cwd backend typecheck",
    "typecheck:frontend": "bun run --cwd frontend typecheck",
    "typecheck:landing": "bun run --cwd landing typecheck",
    "dev:embed": "bun run --cwd embed dev",
    "build:embed": "bun run --cwd embed build",
    "lint:embed": "bun run --cwd embed lint",
    "typecheck:embed": "bun run --cwd embed typecheck"
  },
  "dependencies": {
    "@langchain/openrouter": "^0.3.0",
    "@livekit/agents": "^1.4.5",
    "@types/archiver": "^7.0.0",
    "archiver": "^8.0.0",
    "qrcode": "^1.5.4",
    "react-easy-crop": "^5.5.7",
    "sharp": "^0.34.5",
    "vite-bundle-analyzer": "^1.3.8"
  },
  "devDependencies": {
    "@types/qrcode": "^1.5.6"
  }
}
